generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id   String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name String @unique
  age  Int

  readings Reading[]

  @@map("users")
}

model Author {
  id   String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name String @unique

  books Book[]

  @@map("authors")
}

model LiteraryGenre {
  id   String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name Genre

  books BookLiteraryGenre[]

  @@map("literary_genres")
}

model Book {
  id       String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  authorId String @map("author_id") @db.Uuid
  title    String

  author Author @relation(fields: [authorId], references: [id])

  genres   BookLiteraryGenre[]
  readings Reading[]

  @@map("books")
}

model BookLiteraryGenre {
  bookId          String @map("book_id") @db.Uuid
  literaryGenreId String @map("literary_genre_id") @db.Uuid

  book          Book          @relation(fields: [bookId], references: [id])
  literaryGenre LiteraryGenre @relation(fields: [literaryGenreId], references: [id])

  @@id([bookId, literaryGenreId])
  @@map("book_literary_genres")
}

model Reading {
  id     String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId String        @map("user_id") @db.Uuid
  bookId String        @map("book_id") @db.Uuid
  rating Int
  status ReadingStatus

  user User @relation(fields: [userId], references: [id])
  book Book @relation(fields: [bookId], references: [id])

  @@unique([userId, bookId])
  @@map("readings")
}

enum ReadingStatus {
  READ
  WANT_TO_READ
}

enum Genre {
  FANTASY
  SCIENCE_FICTION
  ROMANCE
  HORROR
  THRILLER
  MYSTERY
  ADVENTURE
  DRAMA
  HISTORICAL_FICTION
  DYSTOPIA
  BIOGRAPHY
  AUTOBIOGRAPHY
  HISTORY
  PHILOSOPHY
  SELF_HELP
  BUSINESS
  SCIENCE
  TECHNOLOGY
  POETRY
  CHILDREN
}
